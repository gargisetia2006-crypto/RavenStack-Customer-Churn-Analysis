import pandas as pd
accounts = pd.read_csv('ravenstack_accounts.csv')
subscriptions = pd.read_csv('ravenstack_subscriptions.csv')
usage = pd.read_csv('ravenstack_feature_usage.csv')
tickets = pd.read_csv('ravenstack_support_tickets.csv')
churn = pd.read_csv('ravenstack_churn_events.csv')
print("Accounts:", accounts.shape)
print("Subscriptions:", subscriptions.shape)
print("Usage:", usage.shape)
print("Tickets:", tickets.shape)
print("Churn:", churn.shape)
Aggregate Subscription Features
subscription_features = (
    subscriptions
    .groupby('account_id')
    .agg({
        'subscription_id': 'count',
        'mrr_amount': 'mean',
        'arr_amount': 'mean',
        'upgrade_flag': 'sum',
        'downgrade_flag': 'sum',
        'auto_renew_flag': 'sum',
        'is_trial': 'sum'
    })
    .reset_index()
)

subscription_features.rename(columns={
    'subscription_id':'total_subscriptions',
    'mrr_amount':'avg_mrr',
    'arr_amount':'avg_arr',
    'upgrade_flag':'total_upgrades',
    'downgrade_flag':'total_downgrades',
    'auto_renew_flag':'auto_renew_count',
    'is_trial':'trial_count'
}, inplace=True)

subscription_features.head()
Create Usage Features
usage_with_account = usage.merge(
    subscriptions[['subscription_id','account_id']],
    on='subscription_id',
    how='left'
)

usage_with_account.head()
usage_features = (
    usage_with_account
    .groupby('account_id')
    .agg({
        'usage_count':'sum',
        'usage_duration_secs':'mean',
        'error_count':'sum',
        'is_beta_feature':'sum'
    })
    .reset_index()
)

usage_features.rename(columns={
    'usage_count':'total_usage',
    'usage_duration_secs':'avg_usage_duration',
    'error_count':'total_errors',
    'is_beta_feature':'beta_feature_usage'
}, inplace=True)

usage_features.head()
Create Ticket Features
ticket_features = (
    tickets
    .groupby('account_id')
    .agg({
        'ticket_id':'count',
        'resolution_time_hours':'mean',
        'first_response_time_minutes':'mean',
        'satisfaction_score':'mean',
        'escalation_flag':'sum'
    })
    .reset_index()
)

ticket_features.rename(columns={
    'ticket_id':'ticket_count',
    'resolution_time_hours':'avg_resolution_time',
    'first_response_time_minutes':'avg_first_response',
    'satisfaction_score':'avg_satisfaction',
    'escalation_flag':'total_escalations'
}, inplace=True)

ticket_features.head()
Create Churn Features
churn_features = (
    churn
    .groupby('account_id')
    .agg({
        'refund_amount_usd':'sum',
        'preceding_upgrade_flag':'sum',
        'preceding_downgrade_flag':'sum',
        'is_reactivation':'sum',
        'churn_event_id':'count'
    })
    .reset_index()
)

churn_features.rename(columns={
    'refund_amount_usd':'total_refund',
    'preceding_upgrade_flag':'pre_upgrade_count',
    'preceding_downgrade_flag':'pre_downgrade_count',
    'is_reactivation':'reactivation_count',
    'churn_event_id':'churn_events_count'
}, inplace=True)

churn_features.head()
customer360 = accounts.copy()
customer360 = customer360.merge(
    subscription_features,
    on='account_id',
    how='left'
)
customer360 = customer360.merge(
    usage_features,
    on='account_id',
    how='left'
)
customer360 = customer360.merge(
    ticket_features,
    on='account_id',
    how='left'
)
customer360 = customer360.merge(
    churn_features,
    on='account_id',
    how='left'
)
customer360.info()
customer360.head()
customer360.isnull().sum()
customer360.to_csv(
    "customer360.csv",
    index=False
)
Fill Ticket Feature Missing Values
customer360['ticket_count'] = customer360['ticket_count'].fillna(0)

customer360['avg_resolution_time'] = customer360['avg_resolution_time'].fillna(0)

customer360['avg_first_response'] = customer360['avg_first_response'].fillna(0)

customer360['avg_satisfaction'] = customer360['avg_satisfaction'].fillna(3)

customer360['total_escalations'] = customer360['total_escalations'].fillna(0)
Fill Churn Feature Missing Values

These customers simply never churned.
churn_cols = [
    'total_refund',
    'pre_upgrade_count',
    'pre_downgrade_count',
    'reactivation_count',
    'churn_events_count'
]

customer360[churn_cols] = customer360[churn_cols].fillna(0)
customer360.isnull().sum().sum()
customer360.to_csv(
    "customer360_clean.csv",
    index=False
)
customer360.isnull().sum()
