import pandas as pd
customer360 = pd.read_csv('/content/customer360.csv')
customer360['signup_date'] = pd.to_datetime(
    customer360['signup_date'],
    dayfirst=True
)

today = pd.Timestamp.today()

customer360['tenure_days'] = (
    today - customer360['signup_date']
).dt.days
customer360[['signup_date','tenure_days']].head()
from sklearn.preprocessing import MinMaxScaler

scaler = MinMaxScaler()

customer360['usage_score'] = (
    scaler.fit_transform(
        customer360[['total_usage']]
    ) * 100
)
customer360['support_score'] = (
    customer360['avg_satisfaction'] * 20
    -
    customer360['total_escalations'] * 5
)

customer360['support_score'] = (
    customer360['support_score']
    .clip(0,100)
)
customer360['subscription_stability'] = (
    customer360['auto_renew_count']
    +
    customer360['total_upgrades']
    -
    customer360['total_downgrades']
)
customer360['subscription_stability'] = (
    scaler.fit_transform(
        customer360[['subscription_stability']]
    ) * 100
)
customer360['customer_health_score'] = (
    0.4 * customer360['usage_score']
    +
    0.3 * customer360['support_score']
    +
    0.3 * customer360['subscription_stability']
)
def health_category(score):

    if score >= 80:
        return 'Healthy'

    elif score >= 60:
        return 'Good'

    elif score >= 40:
        return 'At Risk'

    else:
        return 'Critical'

customer360['health_status'] = (
    customer360['customer_health_score']
    .apply(health_category)
)
customer360[
    [
        'tenure_days',
        'usage_score',
        'support_score',
        'subscription_stability',
        'customer_health_score',
        'health_status'
    ]
].head()
customer360.to_csv(
    "customer360_feature_engineered.csv",
    index=False
)
